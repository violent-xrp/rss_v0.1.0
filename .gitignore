# ==============================================================================
# RSS v3 — .gitignore
# ==============================================================================

# Python bytecode and cache
__pycache__/
*.pyc
*.pyo
*.pyd

# SQLite database files (runtime artifacts, regenerated by tests)
*.db
*.db-shm
*.db-wal

# Runtime exports (generated by test runs and demos)
rss_trace_export.json

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS-specific
Thumbs.db

# Build artifacts (future — for when you package for PyPI)
build/
dist/
*.egg-info/
*.egg

# Test / coverage output
.pytest_cache/
.coverage
htmlcov/
